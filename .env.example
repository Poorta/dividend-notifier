# ============================================================
# Dividend Notifier — 环境变量
# 
# 所有用户配置（邮件/筛选/时间/颜色）请通过 Web 界面设置:
#   启动服务 → 打开浏览器 → /settings
#
# 此文件仅保留系统级配置，首次启动无需修改。
# ============================================================

# === 网络代理 (可选) ===
HTTP_PROXY=
HTTPS_PROXY=

# === 邮件默认值 (首次 Web 填写后将覆盖) ===
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_HOST=smtp.qq.com
MAIL_PORT=465

# === 收件人默认值 ===
RECIPIENTS=

# === 推送时间默认值 ===
SEND_HOUR=8
SEND_MINUTE=30

# === 筛选默认值 ===
MIN_CONSECUTIVE_YEARS=3
MIN_MARKET_CAP=
MIN_DIVIDEND_YIELD=
MAX_PE_RATIO=
MAX_PB_RATIO=
EXCLUDE_ST=1
EXCLUDE_NEW_LISTING_DAYS=365

# === 颜色默认值 ===
COLOR_DIV_YIELD_RED=5.0
COLOR_DIV_YIELD_GREEN=3.0
COLOR_YTD_RED=0.0
COLOR_YTD_GREEN=-5.0
COLOR_CONSECUTIVE_RED=10
COLOR_CONSECUTIVE_GREEN=5

# === 输出配置 ===
OUTPUT_DIR=./output
OUTPUT_FORMAT=xlsx,pdf
PDF_PAGE_ORIENTATION=landscape
PDF_PAGE_SIZE=A4
PDF_FONT_PATH=

# === 运行模式 ===
LOG_LEVEL=INFO
